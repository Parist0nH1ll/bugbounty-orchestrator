# ==========================================
# AI 漏洞挖掘平台 - 环境变量配置
# 复制此文件为 .env 后修改
# ==========================================

# --- 数据库 ---
DATABASE_URL=sqlite:///./data/orchestrator.db
# PostgreSQL 示例: postgresql://user:pass@postgres:5432/orchestrator

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- LLM / AI ---
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o

# --- 工具路径 (容器内路径) ---
SUBFINDER_PATH=/usr/local/bin/subfinder
# Strix 通过 pip install strix-agent 安装，命令名 strix（在 PATH 中）
STRIX_PATH=strix
NAABU_PATH=/usr/local/bin/naabu

# --- Strix 独立 LLM 配置（可选，留空则复用 LLM_API_KEY + LLM_MODEL）---
STRIX_LLM=

# --- 任务超时 (秒) ---
SUBDOMAIN_TIMEOUT=600
DNS_RESOLVE_TIMEOUT=300
STRIX_SCAN_TIMEOUT=7200
PORT_SCAN_TIMEOUT=300
AI_ANALYSIS_TIMEOUT=300

# --- 并发控制 ---
DNS_CONCURRENCY=50
SUBDOMAIN_CONCURRENCY=5

# --- Web ---
API_PORT=8000
FRONTEND_PORT=80
STREAMLIT_PORT=8501
